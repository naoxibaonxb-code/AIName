# MySQL
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ainame

# PostgreSQL for LangGraph checkpoint
PG_NAME=postgresql
PG_USER=postgres
PG_PWD=your-postgres-password
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB_NAME=ainame

# Long-term agent memory in PostgreSQL + pgvector
MEMORY_ENABLED=True
MEMORY_EMBEDDING_MODEL=nomic-embed-text
MEMORY_EMBEDDING_DIM=768
MEMORY_TOP_K=4
MEMORY_TIMEOUT_SECONDS=3

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=123456
RABBITMQ_VHOST=/
RABBITMQ_KNOWLEDGE_QUEUE=ainame.knowledge.tasks

# Mail
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-auth-code
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_FROM=your-email@example.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Auth
JWT_SECRET_KEY=replace-with-a-long-random-secret

# AI
DEEPSEEK_API_KEY=your-deepseek-api-key

# History retention
HISTORY_RETENTION_DAYS=30
HISTORY_MAX_PER_USER=100
HISTORY_CLEANUP_INTERVAL_SECONDS=21600

# Quota and rate limit
DAILY_FREE_GENERATIONS=3
NAME_USER_RATE_LIMIT=6
NAME_IP_RATE_LIMIT=20
NAME_GLOBAL_RATE_LIMIT=120
NAME_GENERATION_LOCK_SECONDS=120

# Alipay sandbox payment experiment
ALIPAY_SANDBOX_ENABLED=False
ALIPAY_APP_ID=your-sandbox-app-id
ALIPAY_PRIVATE_KEY=your-sandbox-app-private-key
ALIPAY_PUBLIC_KEY=your-alipay-sandbox-public-key
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=http://127.0.0.1:8000/payments/alipay/notify
ALIPAY_RETURN_URL=http://127.0.0.1:8000/payments/alipay/return-page
ALIPAY_FRONTEND_RETURN_URL=http://127.0.0.1:5173/#/pages/profile/profile
ALIPAY_TEST_SUBJECT=AIName 生成机会 x1
